# ============================================================
# ConnectorOS Scout — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# --- API Keys (REQUIRED) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database ---
DATABASE_URL=sqlite:///data/connectoros.db
# Supabase (Postgres URI; preferred aliases):
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# NOTE: SUPABASE_URL (https://...supabase.co) is the API URL and will not work as DATABASE_URL.

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Frontend ---
FRONTEND_PORT=5173
