# ============================================================
# ConnectorOS Scout — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# --- API Keys (REQUIRED) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database (Supabase/Postgres REQUIRED) ---
# Use Supabase pooler URI for serverless deployments.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Optional aliases (if you prefer not to set DATABASE_URL):
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# API URL (not DB connection string):
SUPABASE_URL=https://[project-ref].supabase.co

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Frontend ---
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
# Comma-separated list for backend CORS (set this on Render to your Vercel frontend URL).
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://scrapper-connector.vercel.app

# Frontend API base (set this on Vercel to your Render backend URL + /api)
# Example:
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
