# ============================================================
# ConnectorOS Scout — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# --- API Keys (REQUIRED) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database ---
DATABASE_URL=sqlite:///data/connectoros.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Frontend ---
FRONTEND_PORT=5173
